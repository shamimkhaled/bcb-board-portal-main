{
  "name": "bcb-directors-affairs-automation-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3005",
    "build": "next build",
    "start": "next start -p 3005",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/test-auth-security.ts && tsx scripts/test-permissions.ts && tsx scripts/test-secure-viewer.ts && tsx scripts/test-appearance.ts",
    "db:init": "node scripts/init-sqlite-db.mjs && prisma generate && prisma db seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed",
    "permissions:seed": "tsx scripts/seed-permissions.ts",
    "appearance:seed": "tsx scripts/seed-appearance.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.4",
    "postcss": "^8.4.49",
    "prisma": "^6.10.1",
    "sql.js": "^1.14.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
