DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
AUTH_SECRET="replace-with-at-least-32-random-bytes-before-production"
# Optional: force Secure cookies on/off. Leave unset to auto-detect HTTPS
# (localhost production builds stay non-Secure so MFA works over http://).
# COOKIE_SECURE=true

# Push / PWA (optional locally)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@domain

# Store packaging (production)
# STORE_ORIGIN=https://your-app.vercel.app
# STORE_HOST=your-app.vercel.app
# CAPACITOR_SERVER_URL=https://your-app.vercel.app
# TWA_PACKAGE_NAME=bd.org.bcb.directors.portal.twa
# TWA_SHA256_CERT_FINGERPRINTS=
# IOS_BUNDLE_ID=bd.org.bcb.directors.portal
# IOS_TEAM_ID=
